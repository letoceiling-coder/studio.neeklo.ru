# ── App ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3016
WORKER_CONCURRENCY=4
CORS_ORIGIN=https://studio.neeklo.ru,http://localhost:3000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://studio:studio@localhost:5435/studio_neeklo?schema=public

# ── Redis (BullMQ) ───────────────────────────────────
REDIS_URL=redis://localhost:6383

# ── JWT / Auth ───────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# ── S3 / MinIO ───────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=studio
S3_SECRET_KEY=studio-secret-key
S3_BUCKET=studio-assets
S3_PUBLIC_URL=http://localhost:9000/studio-assets

# ── Neeklo Platform API (generation) ─────────────────
NEEKLO_GENERATION_API_URL=https://api.neeklo.ru
NEEKLO_GENERATION_API_KEY=

# ── Neeklo Media API ─────────────────────────────────
NEEKLO_MEDIA_API_URL=https://media.neeklo.ru/api/v1

# ── Neeklo Platform IDE (site builder) ───────────────
NEEKLO_PLATFORM_API_URL=https://cursor.neeklo.ru/api/v1
NEEKLO_PLATFORM_API_KEY=ncsr_...
NEEKLO_PLATFORM_DEFAULT_USER=

# ── Billing ──────────────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_WEBHOOK_SECRET=
